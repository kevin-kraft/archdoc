{
  "$defs": {
    "CatalogIdentity": {
      "properties": {
        "aliases": {
          "items": {
            "type": "string"
          },
          "title": "Aliases",
          "type": "array"
        },
        "catalog_id": {
          "title": "Catalog Id",
          "type": "string"
        },
        "display_name": {
          "title": "Display Name",
          "type": "string"
        },
        "logical_id": {
          "title": "Logical Id",
          "type": "string"
        },
        "source_id": {
          "title": "Source Id",
          "type": "string"
        }
      },
      "required": [
        "catalog_id",
        "logical_id",
        "source_id",
        "display_name"
      ],
      "title": "CatalogIdentity",
      "type": "object"
    },
    "DetectionConfidence": {
      "enum": [
        "exact",
        "high",
        "medium",
        "low",
        "unknown"
      ],
      "title": "DetectionConfidence",
      "type": "string"
    },
    "DetectionInfo": {
      "properties": {
        "confidence": {
          "$ref": "#/$defs/DetectionConfidence",
          "default": "unknown"
        },
        "evidence": {
          "items": {
            "type": "string"
          },
          "title": "Evidence",
          "type": "array"
        },
        "method": {
          "title": "Method",
          "type": "string"
        },
        "rule": {
          "title": "Rule",
          "type": "string"
        }
      },
      "required": [
        "method",
        "rule"
      ],
      "title": "DetectionInfo",
      "type": "object"
    },
    "OperationLinkEndpoint": {
      "properties": {
        "class_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Class Name"
        },
        "method_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Method Name"
        },
        "operation_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Operation Id"
        },
        "qualified_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Qualified Name"
        },
        "service_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Service Id"
        }
      },
      "title": "OperationLinkEndpoint",
      "type": "object"
    },
    "SourceRef": {
      "properties": {
        "file": {
          "title": "File",
          "type": "string"
        },
        "line_end": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Line End"
        },
        "line_start": {
          "title": "Line Start",
          "type": "integer"
        }
      },
      "required": [
        "file",
        "line_start"
      ],
      "title": "SourceRef",
      "type": "object"
    }
  },
  "$id": "https://utilis.local/archdoc/schemas/operation-link-item.schema.json",
  "properties": {
    "call_name": {
      "title": "Call Name",
      "type": "string"
    },
    "confidence": {
      "$ref": "#/$defs/DetectionConfidence",
      "default": "medium"
    },
    "details": {
      "additionalProperties": true,
      "title": "Details",
      "type": "object"
    },
    "detection": {
      "$ref": "#/$defs/DetectionInfo"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "identity": {
      "$ref": "#/$defs/CatalogIdentity"
    },
    "link_type": {
      "title": "Link Type",
      "type": "string"
    },
    "resolved": {
      "default": false,
      "title": "Resolved",
      "type": "boolean"
    },
    "review_status": {
      "default": "generated",
      "title": "Review Status",
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/OperationLinkEndpoint"
    },
    "source_ref": {
      "$ref": "#/$defs/SourceRef"
    },
    "target": {
      "$ref": "#/$defs/OperationLinkEndpoint"
    },
    "variable": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Variable"
    }
  },
  "required": [
    "id",
    "identity",
    "link_type",
    "source",
    "target",
    "call_name",
    "source_ref",
    "detection"
  ],
  "title": "OperationLinkItem",
  "type": "object"
}